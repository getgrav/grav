# Grav environment file
#
# Copy this file to `.env` and uncomment the lines you need. Grav loads `.env`
# automatically at startup, before its configuration is compiled, so the values
# behave like real environment variables and can drive paths, the environment
# name, and any configuration override.
#
# Layering (each later file overrides the earlier ones, but real server-set
# environment variables always take precedence):
#
#   .env                       base defaults (safe to commit)
#   .env.local                 machine-specific overrides (do not commit)
#   .env.<environment>         per-environment, e.g. .env.production
#   .env.<environment>.local   per-environment machine overrides
#
# The <environment> suffix comes from GRAV_ENVIRONMENT below. When it is unset,
# Grav falls back to its usual hostname-based environment detection.

# Select the active environment. Used both for the per-environment .env layers
# above and for multisite configuration under user/env/<environment>.
#GRAV_ENVIRONMENT=production

# Override individual configuration values. Set GRAV_CONFIG to a truthy value to
# turn the feature on, then use GRAV_CONFIG__ keys where double underscores map
# to dots. The examples below set system.cache.enabled and a couple of plugin
# options (plugins.email.mailer.smtp.*) without committing the secret to YAML.
#GRAV_CONFIG=true
#GRAV_CONFIG__system__cache__enabled=true
#GRAV_CONFIG__plugins__email__mailer__smtp__user=postmaster@example.com
#GRAV_CONFIG__plugins__email__mailer__smtp__password=super-secret

# Variable names allow only letters, digits and underscores, so a plugin whose
# slug contains a hyphen (e.g. translation-service) can't be named directly.
# Define an alias with GRAV_CONFIG_ALIAS__ where the hyphenated path lives in the
# value, then reference the alias. The line below sets
# plugins.translation-service.anthropic.api_key.
#GRAV_CONFIG_ALIAS__TRANSLATIONSERVICE=plugins.translation-service
#GRAV_CONFIG__TRANSLATIONSERVICE__anthropic__api_key=changeme

# Override Grav's paths (relative to the site root unless given as absolute).
#GRAV_USER_PATH=user

# Your own secrets are available to plugins and themes through getenv().
#MY_API_KEY=changeme
